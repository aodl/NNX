# Editors
.vscode/
.idea/
**/*~

# OS files
.DS_Store
**/.DS_Store

# icp-cli local network/cache state
.icp/cache/

# Rust
target/

# JavaScript
node_modules/
dist/
playwright-report/
test-results/

# Environment variables
.env

# Generated frontend build artifacts
canisters/frontend/public/generated/*
!canisters/frontend/public/generated/.gitkeep
release-artifacts/

# Generated declarations are normally ignored, but checked-in frontend external declarations are kept.
**/declarations/
!canisters/frontend/web/declarations/
!canisters/frontend/web/declarations/**

# Python/cache
__pycache__/
*.pyc
